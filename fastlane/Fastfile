default_platform(:android)

platform :android do
  desc "Deploy to Play Store"
  lane :deploy do
    gradle(
      task: 'bundle',
      build_type: 'Release',
      # Build the AAB without ABI splits or native-lib compression: Play does its own
      # per-device splitting and prefers uncompressed libs. Splits are reserved for the
      # standalone APKs published to GitHub/IzzyOnDroid.
      properties: {
        'playBundle' => 'true'
      }
    )
    upload_to_play_store(
      track: 'internal',
      aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      release_status: 'completed'
    )
  end
end
